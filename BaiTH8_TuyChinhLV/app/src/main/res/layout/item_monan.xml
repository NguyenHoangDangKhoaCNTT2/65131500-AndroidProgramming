<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_height="52dp"
    android:layout_width="match_parent"
    android:padding="1dp"
    android:orientation="horizontal"
    android:background="#E6D78C"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <ImageView
        android:id="@+id/imAnhDaiDien"
        android:layout_width="50dp"
        android:background="#36FFF6"
        android:layout_height="50dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:paddingLeft="2dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTenMonAn"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text="Món thứ nhất"
            android:textSize="13dp"/>

        <TextView
            android:id="@+id/tvDonGia"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:text="200000đ"
            android:textSize="10dp"/>

        <TextView
            android:id="@+id/tvMoTa"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:text="Nội dung mô tả ở đây"
            android:textSize="10dp"/>

    </LinearLayout>
</LinearLayout>